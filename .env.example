# Server configuration
PORT=8080

# Database type: falkordb, auradb, or realmdb
DB_TYPE=falkordb

# Graph name (optional, default: matchstick)
GRAPH_NAME=matchstick

# ============================================
# FalkorDB Configuration (used when DB_TYPE=falkordb)
# ============================================
FALKORDB_URL=redis://localhost:6379

# ============================================
# AuraDB (Neo4j) Configuration (used when DB_TYPE=auradb)
# ============================================
# Connection URI (obtained from AuraDB console)
AURADB_URI=neo4j+s://your-instance.databases.neo4j.io

# Database username
AURADB_USERNAME=neo4j

# Database password
AURADB_PASSWORD=your-password-here

# Database name (optional, default: neo4j)
AURADB_DATABASE=neo4j

# ============================================
# RealmDB Configuration (used when DB_TYPE=realmdb)
# ============================================
# Path to Realm database file (optional, default: ./data/matchstick.realm)
REALMDB_PATH=./data/matchstick.realm
